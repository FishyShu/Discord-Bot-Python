# Discord bot token (required)
DISCORD_TOKEN=your-bot-token-here

# Spotify API credentials (optional, for Spotify URL support)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Dashboard settings
# Password can be plaintext or a bcrypt hash (starting with $2b$).
# Generate a hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
DASHBOARD_PASSWORD=change-me
DASHBOARD_SECRET=change-me-to-a-random-string
DASHBOARD_PORT=5000

# Set to 1 to allow starting with default DASHBOARD_PASSWORD / DASHBOARD_SECRET (dev only)
ALLOW_DEFAULT_SECRETS=0

# IMPORTANT: The dashboard serves over HTTP. In production, place it behind a
# reverse proxy (e.g. nginx, Caddy, Traefik) with TLS termination.
# Never expose the dashboard directly to the internet without HTTPS.

# Twitch API credentials (optional, for stream notifications)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# AI feature keys
GEMINI_API_KEY=       # Free from https://aistudio.google.com — fallback default model
GROQ_API_KEY=         # Free from https://console.groq.com — preferred free default (14,400 req/day, fast)
ENCRYPTION_KEY=       # Required to store user API keys — generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Optional: additional providers (enter via dashboard API key field)
# DEEPSEEK_API_KEY    — https://platform.deepseek.com (very cheap, excellent quality)
# MISTRAL_API_KEY     — https://console.mistral.ai (free tier available)
# CEREBRAS_API_KEY    — https://cloud.cerebras.ai (free tier, extremely fast)
# OPENROUTER_API_KEY  — https://openrouter.ai (300+ models, many free)
# GITHUB_TOKEN        — https://github.com/settings/tokens (free GPT-4o + Llama access)

# FreeStuff.gg Ed25519 public key for webhook signature verification (required)
# 1. Register at https://dashboard.freestuffbot.xyz
# 2. Create an app, then add a webhook pointing to:
#    https://<your-domain>/freestuff/webhook/freestuffgg
# 3. Copy the Ed25519 public key shown on your app page (base64-encoded) and paste it here.
FREESTUFFGG_PUBKEY=

# Set to 1 to sync slash commands on startup (Discord rate limit: 200/day)
SYNC_COMMANDS=0
