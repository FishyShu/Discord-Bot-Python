# Discord bot token (required)
DISCORD_TOKEN=your-bot-token-here

# Spotify API credentials (optional, for Spotify URL support)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Dashboard settings
# Password can be plaintext or a bcrypt hash (starting with $2b$).
# Generate a hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
DASHBOARD_PASSWORD=change-me
DASHBOARD_SECRET=change-me-to-a-random-string
DASHBOARD_PORT=5000

# Set to 1 to allow starting with default DASHBOARD_PASSWORD / DASHBOARD_SECRET (dev only)
ALLOW_DEFAULT_SECRETS=0

# IMPORTANT: The dashboard serves over HTTP. In production, place it behind a
# reverse proxy (e.g. nginx, Caddy, Traefik) with TLS termination.
# Never expose the dashboard directly to the internet without HTTPS.

# Twitch API credentials (optional, for stream notifications)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# AI feature keys
GEMINI_API_KEY=       # Free from https://aistudio.google.com — default AI model
FAL_API_KEY=          # Optional: fal.ai for /imagine (higher quality than Pollinations)
ENCRYPTION_KEY=       # Required if using /ai config apikey — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Set to 1 to sync slash commands on startup (Discord rate limit: 200/day)
SYNC_COMMANDS=0
