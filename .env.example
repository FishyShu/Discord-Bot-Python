# Discord bot token (required)
DISCORD_TOKEN=your-bot-token-here

# Spotify API credentials (optional, for Spotify URL support)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Dashboard settings
DASHBOARD_PASSWORD=change-me
DASHBOARD_SECRET=change-me-to-a-random-string
DASHBOARD_PORT=5000

# Twitch API credentials (optional, for stream notifications)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Set to 1 to sync slash commands on startup (Discord rate limit: 200/day)
SYNC_COMMANDS=0
